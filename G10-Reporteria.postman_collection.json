        {
          "name": "GET /reports/products (top 5)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('topProducts es array con max 5 elementos', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.topProducts).to.be.an('array');",
                  "  pm.expect(json.topProducts.length).to.be.at.most(5);",
                  "  const p = json.topProducts[0];",
                  "  pm.expect(p).to.have.property('productId');",
                  "  pm.expect(p).to.have.property('revenue');",
