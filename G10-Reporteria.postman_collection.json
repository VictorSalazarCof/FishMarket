{
  "info": {
    "_postman_id": "g10-reporteria-fishmarket-cloud",
    "name": "G10 – Reportería / Batch / Streaming",
    "description": "Colección de pruebas para todos los endpoints del mock G10 – FishMarket Cloud.\nBase URL: https://g10-reporteria-mock.onrender.com\n\nVariables de entorno requeridas:\n- baseUrl: URL base del mock (local o Render)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://g10-reporteria-mock.onrender.com",
      "type": "string"
    },
    {
      "key": "startDate",
      "value": "2025-01-01",
      "type": "string"
    },
    {
      "key": "endDate",
      "value": "2025-01-31",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🟢 Health Check",
      "item": [
        {
          "name": "GET /health",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('status is ok', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('ok');",
                  "  pm.expect(json.service).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "📊 Reportes",
      "item": [
        {
          "name": "GET /reports/sales-summary (por día)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Tiene campo summary', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('summary');",
                  "  pm.expect(json.summary).to.have.property('totalRevenue');",
                  "  pm.expect(json.summary).to.have.property('totalOrders');",
                  "  pm.expect(json.summary).to.have.property('averageOrderValue');",
                  "});",
                  "pm.test('Tiene timeSeries', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.timeSeries).to.be.an('array').that.is.not.empty;",
                  "  const first = json.timeSeries[0];",
                  "  pm.expect(first).to.have.property('date');",
                  "  pm.expect(first).to.have.property('orders');",
                  "  pm.expect(first).to.have.property('revenue');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/reports/sales-summary?startDate={{startDate}}&endDate={{endDate}}&groupBy=day",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "reports", "sales-summary"],
              "query": [
                { "key": "startDate", "value": "{{startDate}}" },
                { "key": "endDate",   "value": "{{endDate}}" },
                { "key": "groupBy",   "value": "day" }
              ]
            }
          }
        },
        {
          "name": "GET /reports/sales-summary (por semana)",
          "event": [
            {
              "listen": "test",
              "script": {
