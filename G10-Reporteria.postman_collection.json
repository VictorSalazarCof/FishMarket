    {
      "name": "📦 Inventario",
      "item": [
        {
          "name": "GET /inventory/low-stock (threshold 10)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Todos los productos están bajo el threshold', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.threshold).to.eql(10);",
                  "  json.products.forEach(p => {",
                  "    pm.expect(p.currentStock).to.be.below(10);",
                  "    pm.expect(p).to.have.property('urgency');",
                  "  });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/inventory/low-stock?threshold=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "inventory", "low-stock"],
              "query": [
                { "key": "threshold", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "GET /inventory/low-stock (threshold crítico 5)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Productos con urgencia critical tienen stock ≤ 3', () => {",
                  "  const json = pm.response.json();",
                  "  const criticals = json.products.filter(p => p.urgency === 'critical');",
                  "  criticals.forEach(p => pm.expect(p.currentStock).to.be.at.most(3));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/inventory/low-stock?threshold=5",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "inventory", "low-stock"],
              "query": [
                { "key": "threshold", "value": "5" }
              ]
            }
          }
        },
        {
          "name": "GET /inventory/low-stock (threshold inválido → 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 para threshold inválido', () => pm.response.to.have.status(400));"
