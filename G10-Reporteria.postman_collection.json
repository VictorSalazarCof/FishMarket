    {
      "name": "⚙️ Batch",
      "item": [
        {
          "name": "POST /batch/recalculate (daily)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 202 Accepted', () => pm.response.to.have.status(202));",
                  "pm.test('Retorna jobId y status queued', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('jobId');",
                  "  pm.expect(json.status).to.eql('queued');",
                  "  pm.expect(json).to.have.property('estimatedCompletionTime');",
                  "  pm.collectionVariables.set('lastJobId', json.jobId);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"targetDate\": \"2025-01-15\",\n  \"scope\": \"daily\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/batch/recalculate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "batch", "recalculate"]
            }
          }
        },
